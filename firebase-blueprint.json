{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "Details for a restaurant table reservation",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer contact email" },
        "peopleCount": { "type": "number", "description": "Number of guests" },
        "date": { "type": "string", "description": "Reservation date (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Reservation time (HH:mm)" },
        "tableId": { "type": "string", "description": "Assigned table identifier" },
        "message": { "type": "string", "description": "Optional customer note" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server-side timestamp" }
      },
      "required": ["name", "email", "peopleCount", "date", "time", "tableId", "createdAt"]
    }
  },
  "firestore": {
    "reservations": {
      "schema": "Reservation",
      "description": "Collection of all table reservations"
    }
  }
}
